---
import ScrollToLink from "../ScrollToLink.astro";
import { construtoraBCopy, construtoraBImages, construtoraBPaths } from "../../data/construtora-b";
---

<section class="bg-white py-10 sm:py-14">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-antares-navy p-6 text-white sm:p-10 lg:p-14">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.85fr] lg:items-center">
        <div class="relative z-10">
          <p class="eyebrow mb-4 text-white/70">Próximo passo</p>
          <h2 class="text-3xl font-semibold tracking-[-0.05em] sm:text-5xl">
            Pronto para tirar o projeto do papel?
          </h2>
          <p class="mt-5 max-w-lg text-lg leading-8 text-white/75">
            Solicite seu orçamento agora. A equipe Antares retorna para orientar as próximas etapas da
            sua obra.
          </p>
          <ScrollToLink
            label={construtoraBCopy.hero.cta}
            href={construtoraBPaths.formAnchor}
            class="mt-8 px-7 py-4 text-base"
          />
        </div>
        <img
          src={construtoraBImages.finalCta}
          alt="Casa residencial entregue pela Antares"
          class="relative z-10 aspect-[4/3] w-full rounded-[2rem] object-cover lg:aspect-[5/4]"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
