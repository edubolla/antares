---
import ScrollToLink from "../ScrollToLink.astro";
import ConstrutoraBGallery from "./ConstrutoraBGallery.astro";
import { construtoraBMainGallery, construtoraBPortfolioGallery } from "../../data/construtora-b-gallery";
import { construtoraBCopy, construtoraBPaths } from "../../data/construtora-b";
---

<section id="portfolio" class="section-padding bg-white pb-0">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">{construtoraBCopy.portfolio.eyebrow}</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-5xl">
        {construtoraBCopy.portfolio.title}
      </h2>
      <p class="mt-4 text-lg text-antares-muted">{construtoraBCopy.portfolio.subtitle}</p>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl gap-3 sm:grid-cols-2">
      {construtoraBCopy.portfolio.highlights.map((item) => (
        <div class="flex items-center gap-3 rounded-2xl border border-antares-line bg-antares-soft px-5 py-4">
          <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-antares-blue text-sm font-bold text-white">✓</span>
          <p class="font-medium text-antares-navy">{item}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="mt-14">
    <ConstrutoraBGallery title="Galeria de obras" images={construtoraBMainGallery} columns="main" />
    <ConstrutoraBGallery id="projetos" title="Projetos" images={construtoraBPortfolioGallery} columns="portfolio" />
  </div>

  <div class="container-page section-padding pb-20 pt-0 sm:pb-24 lg:pb-32">
    <p class="mx-auto max-w-2xl text-center leading-7 text-antares-muted">
      {construtoraBCopy.portfolio.closing}
    </p>

    <div class="mt-8 text-center">
      <ScrollToLink label={construtoraBCopy.portfolio.cta} href={construtoraBPaths.formAnchor} class="px-7 py-4 text-base" />
    </div>
  </div>
</section>
