---
import type { GalleryImage } from "../../data/construtora-b-gallery";

interface Props {
  title: string;
  images: GalleryImage[];
  columns?: "main" | "portfolio";
  id?: string;
}

const { title, images, columns = "main", id } = Astro.props;

const gridClass =
  columns === "portfolio"
    ? "gallery-grid gallery-grid--portfolio"
    : "gallery-grid gallery-grid--main";
---

  <div class="gallery-section" id={id}>
  <h3 class="container-page py-8 text-center text-2xl font-semibold tracking-[-0.04em] text-antares-navy sm:py-10 sm:text-3xl">{title}</h3>
  <div class={`${gridClass}${columns === "portfolio" ? " container-page" : ""}`}>
    {
      images.map((image, index) => (
        <div class={`gallery-item${columns === "portfolio" ? " gallery-item--square" : ""}`}>
          <img
            src={image.src}
            alt={image.alt}
            width={columns === "portfolio" ? "480" : "400"}
            height={columns === "portfolio" ? "480" : "284"}
            loading={index < 4 ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      ))
    }
  </div>
</div>

<style>
  .gallery-grid {
    display: grid;
    gap: 0;
  }

  .gallery-grid--main {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .gallery-grid--portfolio {
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 0.75rem;
    max-width: 72rem;
  }

  .gallery-item img {
    width: 100%;
    height: 284px;
    object-fit: cover;
    display: block;
  }

  .gallery-item--square {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .gallery-grid--portfolio .gallery-item img {
    height: 100%;
  }

  @media (min-width: 481px) {
    .gallery-grid--main {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 640px) {
    .gallery-grid--portfolio {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (min-width: 769px) {
    .gallery-grid--main {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .gallery-grid--portfolio {
      gap: 1.25rem;
    }
  }
</style>
