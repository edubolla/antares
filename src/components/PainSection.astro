---
import CtaLink from "./CtaLink.astro";
import SectionHeader from "./SectionHeader.astro";
import { images } from "../data/landing";

const pains = [
  "Gastar além do previsto",
  "Contratar profissionais errados",
  "Atrasos na obra",
  "Problemas com documentação",
  "Coordenar vários fornecedores",
];
---

<section class="section-padding bg-white">
  <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-stretch">
    <div>
      <SectionHeader
        eyebrow="O desafio"
        title="“Não faço ideia de como construir uma casa.”"
        description="Essa é a dúvida de muitos casais depois de comprar o terreno. Projeto, aprovação, orçamento, fornecedores, cronograma e obra precisam funcionar juntos para o sonho não virar uma sequência de problemas."
      />
      <div class="mt-8 grid gap-3">
        {pains.map((pain) => (
          <div class="flex items-center gap-3 rounded-2xl border border-antares-line bg-white p-4">
            <span class="h-2.5 w-2.5 rounded-full bg-antares-blue"></span>
            <span class="font-medium text-antares-navy">{pain}</span>
          </div>
        ))}
      </div>
      <CtaLink
        label="Quero orientação para começar"
        message="Olá, comprei ou estou comprando um terreno e preciso de orientação para começar a construir."
        class="mt-8"
      />
    </div>

    <div class="relative min-h-[420px] lg:min-h-0">
      <img
        src={images.pain}
        alt="Etapa inicial de obra residencial com fundação em execução"
        class="h-full min-h-[420px] w-full rounded-[2rem] object-cover shadow-premium"
        loading="lazy"
      />
      <div class="mt-4 rounded-[2rem] border border-antares-line bg-antares-soft p-6 lg:absolute lg:bottom-6 lg:left-6 lg:right-6 lg:mt-0 lg:bg-white/95 lg:backdrop-blur">
        <p class="text-lg font-semibold tracking-[-0.03em] text-antares-navy">
          Você não precisa coordenar tudo sozinho.
        </p>
        <p class="mt-2 leading-7 text-antares-muted">
          A ideia é sair da dúvida inicial com um plano claro para projeto, documentação e obra.
        </p>
      </div>
    </div>
  </div>
</section>
