---
import CtaLink from "./CtaLink.astro";
import { images } from "../data/landing";
---

<section class="bg-white py-8">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-antares-navy p-6 text-white shadow-premium sm:p-10 lg:p-16">
      <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
        <div class="relative z-10">
          <p class="eyebrow mb-4">Próximo passo</p>
          <h2 class="max-w-3xl text-4xl font-semibold tracking-[-0.05em] sm:text-5xl lg:text-6xl">
            O próximo passo é entender o caminho certo para o seu terreno.
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-white/75">
            Fale com a Antares para transformar dúvidas sobre projeto, documentação e obra em um plano claro para construir sua casa.
          </p>
          <CtaLink
            label="Começar conversa pelo WhatsApp"
            message="Olá, quero começar uma conversa sobre projeto e execução da minha casa."
            variant="light"
            class="mt-8"
          />
        </div>

        <img
          src={images.finalCta}
          alt="Casa pronta com área externa entregue"
          class="relative z-10 aspect-[4/5] w-full rounded-[2rem] object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
