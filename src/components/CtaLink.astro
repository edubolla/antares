---
import { whatsappUrl } from "../data/landing";

interface Props {
  label: string;
  message?: string;
  variant?: "primary" | "secondary" | "light" | "whatsapp";
  class?: string;
  icon?: "whatsapp";
}

const { label, message, variant = "primary", class: className = "", icon } = Astro.props;

const variants = {
  primary: "bg-antares-blue text-white hover:bg-antares-navy",
  secondary: "border border-antares-line bg-white text-antares-navy hover:border-antares-blue hover:text-antares-blue",
  light: "bg-white text-antares-navy hover:bg-antares-soft",
  whatsapp:
    "bg-[#25D366] text-white shadow-[0_18px_45px_rgba(37,211,102,0.35)] ring-4 ring-[#25D366]/15 hover:bg-[#1FBD5A] hover:shadow-[0_22px_55px_rgba(37,211,102,0.45)]",
};
---

<a
  href={whatsappUrl(message)}
  target="_blank"
  rel="noopener noreferrer"
  class={`inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition duration-200 ${variants[variant]} ${className}`}
>
  {icon === "whatsapp" && (
    <svg viewBox="0 0 32 32" aria-hidden="true" class="h-5 w-5 fill-current">
      <path d="M16.04 3.2A12.74 12.74 0 0 0 5.06 22.4L3.2 29l6.76-1.78A12.73 12.73 0 1 0 16.04 3.2Zm0 23.28a10.6 10.6 0 0 1-5.4-1.48l-.38-.23-4.02 1.06 1.07-3.92-.25-.4a10.55 10.55 0 1 1 8.98 4.97Zm5.8-7.91c-.32-.16-1.88-.93-2.17-1.03-.29-.11-.5-.16-.71.16-.21.32-.82 1.03-1.01 1.24-.18.21-.37.24-.69.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.88-1.76-2.2-.18-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.18.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.71-1.7-.98-2.33-.26-.62-.52-.53-.71-.54h-.61c-.21 0-.56.08-.85.4-.29.32-1.11 1.08-1.11 2.64 0 1.56 1.14 3.07 1.3 3.28.16.21 2.25 3.43 5.44 4.81.76.33 1.35.52 1.81.67.76.24 1.46.21 2.01.13.61-.09 1.88-.77 2.15-1.51.26-.74.26-1.38.18-1.51-.08-.13-.29-.21-.61-.37Z" />
    </svg>
  )}
  {label}
</a>
