---
import { visualPortfolioImages } from "../../data/landing";

const [main, first, second] = visualPortfolioImages;
---

<section id="portfolio" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow mb-4">Portfólio</p>
        <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">Casas que começam com planejamento.</h2>
      </div>
      <p class="max-w-sm text-antares-muted">Veja o padrão de entrega da Antares.</p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1.35fr_0.65fr]">
      <figure class="group relative overflow-hidden rounded-[2.5rem] shadow-premium">
        <img src={main.src} alt={main.alt} class="h-[70vh] min-h-[480px] w-full object-cover transition duration-700 group-hover:scale-[1.03]" loading="lazy" />
        <figcaption class="absolute bottom-6 left-6 rounded-full bg-white/90 px-5 py-2 text-sm font-semibold text-antares-navy backdrop-blur">
          {main.label}
        </figcaption>
      </figure>

      <div class="grid gap-4">
        {[first, second].map((image) => (
          <figure class="group relative overflow-hidden rounded-[2.5rem]">
            <img src={image.src} alt={image.alt} class="h-72 w-full object-cover transition duration-700 group-hover:scale-[1.04] lg:h-full" loading="lazy" />
            <figcaption class="absolute bottom-5 left-5 rounded-full bg-white/90 px-4 py-2 text-xs font-semibold text-antares-navy backdrop-blur">
              {image.label}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
