---
import { visualPortfolioImages } from "../../data/landing";

const [main, first, second] = visualPortfolioImages;
---

<section id="portfolio" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="mb-10 max-w-4xl">
      <p class="eyebrow mb-4">Portfólio</p>
      <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">Casas que começam com planejamento.</h2>
      <p class="mt-5 max-w-sm text-antares-muted">Veja o padrão de entrega da Antares.</p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1.35fr_0.65fr]">
      <figure class="group relative min-h-[560px] overflow-hidden rounded-[2.5rem] bg-antares-navy shadow-premium lg:min-h-[720px]">
        <img src={main.src} alt={main.alt} class="absolute inset-0 block h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]" loading="lazy" />
      </figure>

      <div class="grid gap-4 lg:grid-rows-2">
        {[first, second].map((image) => (
          <figure class="group relative min-h-[320px] overflow-hidden rounded-[2.5rem] bg-antares-navy">
            <img src={image.src} alt={image.alt} class="absolute inset-0 block h-full w-full object-cover transition duration-700 group-hover:scale-[1.04]" loading="lazy" />
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
