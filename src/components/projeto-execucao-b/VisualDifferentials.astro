---
const items = ["Planejamento", "Cronograma", "Gestão completa", "Comunicação"];
---

<section class="bg-white py-20 sm:py-24">
  <div class="container-page">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div>
        <p class="eyebrow mb-4">Entrega</p>
        <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">O que sustenta a obra.</h2>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {items.map((item) => (
          <div class="rounded-[2rem] border border-antares-line bg-antares-soft p-6">
            <p class="text-2xl font-semibold tracking-[-0.04em] text-antares-navy">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
