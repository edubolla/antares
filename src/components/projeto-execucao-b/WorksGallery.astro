---
import { visualPortfolioImages } from "../../data/landing";
---

<section id="obras" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow mb-4">Obras</p>
        <h2 class="text-4xl font-semibold tracking-[-0.05em] sm:text-6xl">Obras e detalhes.</h2>
      </div>
      <p class="max-w-sm text-white/65">Fachadas, interiores e acabamentos executados pela Antares.</p>
    </div>

    <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
      {visualPortfolioImages.map((image, index) => (
        <figure class="group relative mb-4 break-inside-avoid overflow-hidden rounded-[2rem] bg-white/5">
          <img
            src={image.src}
            alt={image.alt}
            class={index % 3 === 0 ? "h-[520px] w-full object-cover transition duration-700 group-hover:scale-[1.03]" : "h-[360px] w-full object-cover transition duration-700 group-hover:scale-[1.03]"}
            loading="lazy"
          />
          <figcaption class="absolute bottom-4 left-4 rounded-full bg-black/35 px-4 py-2 text-xs font-semibold text-white backdrop-blur">
            {image.label}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
