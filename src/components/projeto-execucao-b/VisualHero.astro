---
import CtaLink from "../CtaLink.astro";
import { images } from "../../data/landing";
---

<section class="relative min-h-screen overflow-hidden bg-antares-navy text-white">
  <img
    src={images.hero}
    alt="Casa residencial finalizada pela Antares Construtora"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-antares-navy via-antares-navy/35 to-black/10"></div>

  <div class="container-page relative z-10 flex min-h-screen items-end pb-12 pt-28 sm:pb-16 lg:pb-20">
    <div class="max-w-4xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.24em] text-white/70">Projeto + Execução</p>
      <h1 class="text-5xl font-semibold tracking-[-0.06em] sm:text-7xl lg:text-8xl">
        Do terreno à casa pronta.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-white/80 sm:text-xl">
        Projeto, documentação e construção com uma única equipe.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:items-center">
        <CtaLink
          label="Falar com um especialista"
          message="Olá, vi a versão visual da landing e gostaria de falar com um especialista sobre projeto e execução."
          variant="whatsapp"
          icon="whatsapp"
          class="w-full px-7 py-4 text-base sm:w-auto"
        />
        <a href="#obras" class="inline-flex items-center justify-center rounded-full border border-white/25 px-7 py-4 text-sm font-semibold text-white transition hover:bg-white hover:text-antares-navy">
          Ver obras
        </a>
      </div>
    </div>
  </div>
</section>
