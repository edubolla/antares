---
import { images } from "../../data/landing";

const steps = [
  { title: "Planejar", image: images.process },
  { title: "Aprovar", image: images.solution },
  { title: "Construir", image: images.processFoundation },
  { title: "Entregar", image: images.finalCta },
];
---

<section id="como-funciona" class="section-padding bg-white">
  <div class="container-page">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow mb-4">Processo</p>
      <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">Do primeiro traço à entrega.</h2>
      <p class="mt-5 text-antares-muted">Cada etapa com acompanhamento profissional.</p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, index) => (
        <figure class="group relative overflow-hidden rounded-[2rem] bg-antares-navy">
          <img src={step.image} alt={`Etapa ${step.title.toLowerCase()} da construção`} class="h-[420px] w-full object-cover opacity-85 transition duration-700 group-hover:scale-[1.04]" loading="lazy" />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-antares-navy to-transparent p-6">
            <span class="text-sm font-semibold text-white/55">{String(index + 1).padStart(2, "0")}</span>
            <p class="mt-2 text-3xl font-semibold tracking-[-0.05em] text-white">{step.title}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
