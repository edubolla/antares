---
import { construtoraTestimonials } from "../../data/construtora";
---

<section id="depoimentos" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Depoimentos</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        Quem construiu com a Antares.
      </h2>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {construtoraTestimonials.map((testimonial) => (
        <blockquote class="rounded-[2rem] border border-antares-line bg-white p-6">
          <p class="leading-7 text-antares-muted">"{testimonial.quote}"</p>
          <footer class="mt-5 font-semibold text-antares-navy">{testimonial.name}</footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
