---
import { construtoraPortfolio } from "../../data/construtora";

const [main, first, second, ...rest] = construtoraPortfolio;
---

<section id="obras" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="mb-10 max-w-2xl">
      <p class="eyebrow mb-4">Obras</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] sm:text-5xl">Residências entregues por nós.</h2>
      <p class="mt-4 text-white/70">Fachadas, interiores e acabamentos executados pela Antares em Canoas e região.</p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1.35fr_0.65fr]">
      <figure class="group relative min-h-[420px] overflow-hidden rounded-[2.5rem] bg-white/5 lg:min-h-[560px]">
        <img
          src={main.src}
          alt={main.alt}
          class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
          loading="eager"
        />
      </figure>
      <div class="grid gap-4 lg:grid-rows-2">
        {[first, second].map((image) => (
          <figure class="group relative min-h-[200px] overflow-hidden rounded-[2.5rem] bg-white/5">
            <img
              src={image.src}
              alt={image.alt}
              class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.04]"
              loading="lazy"
            />
          </figure>
        ))}
      </div>
    </div>

    <div class="mt-4 columns-1 gap-4 sm:columns-2 lg:columns-3">
      {rest.map((image, index) => (
        <figure class="group relative mb-4 break-inside-avoid overflow-hidden rounded-[2rem] bg-white/5">
          <img
            src={image.src}
            alt={image.alt}
            class={index % 3 === 0 ? "h-[420px] w-full object-cover transition duration-700 group-hover:scale-[1.03]" : "h-[300px] w-full object-cover transition duration-700 group-hover:scale-[1.03]"}
            loading="lazy"
          />
        </figure>
      ))}
    </div>
  </div>
</section>
