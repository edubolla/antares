---
import { construtoraPortfolio } from "../../data/construtora";
---

<section id="obras" class="section-padding bg-antares-navy text-white">
  <div class="container-page mb-10 max-w-2xl">
    <p class="eyebrow mb-4">Obras</p>
    <h2 class="text-3xl font-semibold tracking-[-0.05em] sm:text-5xl">Residências entregues por nós.</h2>
    <p class="mt-4 text-white/70">Fachadas, interiores e acabamentos executados pela Antares em Canoas e região.</p>
  </div>

  <div class="grid grid-cols-1 gap-1 sm:grid-cols-2">
    {construtoraPortfolio.map((image, index) => (
      <figure class="group relative aspect-[4/3] overflow-hidden lg:aspect-[16/11]">
        <img
          src={image.src}
          alt={image.alt}
          class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]"
          loading={index < 2 ? "eager" : "lazy"}
        />
      </figure>
    ))}
  </div>
</section>
