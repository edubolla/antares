---
import { construtoraPortfolio } from "../../data/construtora";
---

<section id="obras" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Obras</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] sm:text-4xl">
        Residências entregues.
      </h2>
      <p class="mt-4 text-white/70">
        Fachadas, interiores e acabamentos executados pela Antares.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {construtoraPortfolio.map((image) => (
        <figure class="overflow-hidden rounded-[2rem]">
          <img
            src={image.src}
            alt={image.alt}
            class="aspect-[4/3] w-full object-cover transition duration-500 hover:scale-[1.02]"
            loading="lazy"
          />
        </figure>
      ))}
    </div>
  </div>
</section>
