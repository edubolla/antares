---
import CtaLink from "../CtaLink.astro";
import { construtoraImages, construtoraMessages } from "../../data/construtora";
---

<section class="bg-white py-8">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-antares-navy p-6 text-white sm:p-10 lg:p-14">
      <div class="grid gap-8 lg:grid-cols-[1fr_0.85fr] lg:items-center">
        <div class="relative z-10">
          <p class="eyebrow mb-4">Próximo passo</p>
          <h2 class="text-4xl font-semibold tracking-[-0.05em] sm:text-5xl">
            Vamos conversar sobre sua obra?
          </h2>
          <p class="mt-5 max-w-lg text-lg leading-8 text-white/75">
            Fale com a Antares pelo WhatsApp e entenda como podemos ajudar.
          </p>
          <CtaLink
            label="Falar com a Antares"
            message={construtoraMessages.default}
            variant="whatsapp"
            icon="whatsapp"
            class="mt-8 px-7 py-4 text-base"
          />
        </div>
        <img
          src={construtoraImages.finalCta}
          alt="Casa residencial entregue pela Antares"
          class="relative z-10 aspect-[4/3] w-full rounded-[2rem] object-cover lg:aspect-[5/4]"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
