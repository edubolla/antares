---
import CtaLink from "../CtaLink.astro";
import { construtoraFaqs, construtoraMessages } from "../../data/construtora";
---

<section id="faq" class="section-padding bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Dúvidas</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        Perguntas frequentes.
      </h2>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl gap-3">
      {construtoraFaqs.map((faq) => (
        <details class="group rounded-[2rem] border border-antares-line bg-white p-6">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-antares-navy">
            {faq.question}
            <span class="text-2xl text-antares-blue transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-4 leading-7 text-antares-muted">{faq.answer}</p>
        </details>
      ))}
    </div>

    <div class="mt-10 text-center">
      <CtaLink label="Tirar uma dúvida" message={construtoraMessages.default} />
    </div>
  </div>
</section>
