---
import { construtoraBenefits } from "../../data/construtora";
---

<section id="beneficios" class="section-padding bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Por que a Antares</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        O que muda quando é a equipe certa.
      </h2>
    </div>

    <div class="mx-auto mt-10 grid max-w-3xl gap-4 sm:grid-cols-2">
      {construtoraBenefits.map((benefit) => (
        <div class="flex gap-3 rounded-2xl border border-antares-line bg-antares-soft px-5 py-5">
          <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-antares-blue text-xs font-bold text-white">✓</span>
          <div>
            <h3 class="font-semibold text-antares-navy">{benefit.title}</h3>
            <p class="mt-1 text-sm leading-6 text-antares-muted">{benefit.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
