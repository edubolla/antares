---
import CtaLink from "../CtaLink.astro";
import { construtoraMoments } from "../../data/construtora";
---

<section class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Seu momento</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        Em que etapa você está?
      </h2>
      <p class="mt-4 text-antares-muted">
        Escolha o caminho mais próximo da sua situação.
      </p>
    </div>

    <div class="mx-auto mt-10 grid max-w-4xl gap-4 md:grid-cols-2">
      {construtoraMoments.map((moment) => (
        <article class="flex flex-col rounded-[2rem] border border-antares-line bg-white p-6">
          <h3 class="text-xl font-semibold tracking-[-0.03em] text-antares-navy">{moment.title}</h3>
          <p class="mt-3 flex-1 leading-7 text-antares-muted">{moment.description}</p>
          <CtaLink label={moment.cta} message={moment.message} class="mt-6 w-full" />
        </article>
      ))}
    </div>
  </div>
</section>
