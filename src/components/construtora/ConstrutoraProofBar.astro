---
import { construtoraProof } from "../../data/construtora";
---

<section class="border-b border-antares-line bg-white py-6">
  <div class="container-page flex flex-col items-center gap-3 text-center text-sm font-medium text-antares-muted sm:flex-row sm:justify-center sm:gap-6">
    <span class="font-semibold text-antares-navy">{construtoraProof.years}</span>
    <span class="hidden h-1 w-1 rounded-full bg-antares-line sm:block"></span>
    <span>{construtoraProof.regionsLabel}</span>
    <span class="hidden h-1 w-1 rounded-full bg-antares-line sm:block"></span>
    <span>{construtoraProof.method}</span>
  </div>
</section>
