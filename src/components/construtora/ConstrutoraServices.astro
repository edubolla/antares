---
import { construtoraServices } from "../../data/construtora";
---

<section id="servicos" class="section-padding bg-white">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Serviços</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        O que a Antares faz.
      </h2>
      <p class="mt-4 text-antares-muted">
        Construção residencial com método, do planejamento à entrega.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {construtoraServices.map((service) => (
        <div class="rounded-[2rem] border border-antares-line bg-antares-soft p-6 text-center">
          <h3 class="text-xl font-semibold tracking-[-0.03em] text-antares-navy">{service.title}</h3>
          <p class="mt-3 text-sm leading-6 text-antares-muted">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
