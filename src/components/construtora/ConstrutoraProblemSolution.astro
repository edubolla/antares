---
import { construtoraProblem, construtoraSolution } from "../../data/construtora";
---

<section class="section-padding bg-antares-soft">
  <div class="container-page grid gap-10 lg:grid-cols-2 lg:gap-14">
    <div>
      <p class="eyebrow mb-4">{construtoraProblem.eyebrow}</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        {construtoraProblem.title}
      </h2>
      <div class="mt-5 space-y-4 leading-7 text-antares-muted">
        {construtoraProblem.paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>

    <div class="rounded-[2rem] border border-antares-line bg-white p-8">
      <p class="eyebrow mb-4">{construtoraSolution.eyebrow}</p>
      <h2 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
        {construtoraSolution.title}
      </h2>
      <p class="mt-5 leading-7 text-antares-muted">{construtoraSolution.paragraph}</p>
    </div>
  </div>
</section>
