---
import CtaLink from "../CtaLink.astro";
import { construtoraImages, construtoraMessages } from "../../data/construtora";
---

<section class="relative min-h-screen overflow-hidden bg-antares-navy text-white">
  <img
    src={construtoraImages.hero}
    alt="Casa residencial finalizada pela Antares Construtora"
    class="absolute inset-0 h-full w-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-antares-navy via-antares-navy/45 to-black/10"></div>

  <div class="container-page relative z-10 flex min-h-screen items-end pb-14 pt-28 sm:pb-20 lg:pb-24">
    <div class="max-w-3xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.24em] text-white/70">Construtora em Canoas e região</p>
      <h1 class="text-4xl font-semibold tracking-[-0.06em] sm:text-6xl lg:text-7xl">
        A empresa certa para construir sua casa do zero.
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-8 text-white/80 sm:text-xl">
        Projeto, documentação e execução com a mesma equipe, do primeiro desenho até a entrega da chave.
      </p>
      <div class="mt-9">
        <CtaLink
          label="Falar agora com a Antares"
          message={construtoraMessages.default}
          variant="whatsapp"
          icon="whatsapp"
          class="w-full px-7 py-4 text-base sm:w-auto"
        />
        <p class="mt-3 text-sm text-white/60">Direto no WhatsApp · resposta rápida · sem compromisso</p>
      </div>
    </div>
  </div>
</section>
