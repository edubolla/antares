---
import CtaLink from "./CtaLink.astro";
import { images, navigation } from "../data/landing";

interface Props {
  navItems?: typeof navigation;
  ctaLabel?: string;
  ctaMessage?: string;
  ctaHref?: string;
}

const {
  navItems = navigation,
  ctaLabel = "Falar no WhatsApp",
  ctaMessage = "Olá, comprei um terreno e quero entender como a Antares pode me ajudar com projeto e execução.",
  ctaHref,
} = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-white/70 bg-white/90 backdrop-blur-xl">
  <div class="container-page flex h-20 items-center justify-between gap-6">
    <a href="#" aria-label="Antares Construtora">
      <img src={images.logoBlue} alt="Antares Construtora" class="h-11 w-auto" />
    </a>

    <nav class="hidden items-center gap-8 text-sm font-medium text-antares-muted lg:flex">
      {navItems.map((item) => (
        <a href={item.href} class="transition hover:text-antares-blue">
          {item.label}
        </a>
      ))}
    </nav>

    {
      ctaHref ? (
        <a
          href={ctaHref}
          class="hidden rounded-full bg-antares-blue px-6 py-3 text-sm font-semibold text-white transition hover:bg-antares-navy sm:inline-flex"
        >
          {ctaLabel}
        </a>
      ) : (
        <CtaLink label={ctaLabel} message={ctaMessage} class="hidden sm:inline-flex" />
      )
    }
  </div>
</header>
