---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionMessages, executionPortfolioImages } from "../../data/execucaoObra";
---

<section id="portfolio" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
      <SectionHeader
        eyebrow="Portfólio"
        title="Obras executadas com atenção ao detalhe."
        description="Fachadas, interiores e acabamentos reais que demonstram o padrão de execução da Antares em obras residenciais."
        tone="dark"
      />
      <CtaLink
        label="Ver análise para meu projeto"
        message={executionMessages.projectAnalysis}
        variant="light"
      />
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-8">
      {executionPortfolioImages.map((image, index) => (
        <figure class={index === 0 ? "sm:col-span-2 lg:col-span-4 lg:row-span-2" : "lg:col-span-2"}>
          <img
            src={image.src}
            alt={image.alt}
            class="h-64 w-full rounded-[2rem] object-cover sm:h-80 lg:h-full lg:min-h-72"
            loading="lazy"
          />
          <figcaption class="mt-3 text-sm font-medium text-white/70">{image.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
