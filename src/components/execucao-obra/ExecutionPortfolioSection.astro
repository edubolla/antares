---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionMessages, executionPortfolioImages } from "../../data/execucaoObra";
---

<section id="portfolio" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="max-w-3xl">
      <SectionHeader
        eyebrow="Portfólio"
        title="Obras executadas com atenção ao detalhe."
        description="Fachadas, interiores e acabamentos reais que demonstram o padrão de execução da Antares em obras residenciais."
        tone="dark"
      />
      <CtaLink
        label="Ver análise para meu projeto"
        message={executionMessages.projectAnalysis}
        variant="light"
        class="mt-8"
      />
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {executionPortfolioImages.map((image) => (
        <figure class="rounded-[2rem] border border-white/10 bg-white/5 p-3">
          <img
            src={image.src}
            alt={image.alt}
            class="h-64 w-full rounded-[1.5rem] object-cover sm:h-72"
            loading="lazy"
          />
          <figcaption class="px-2 pb-1 pt-4 text-sm font-medium leading-6 text-white/70">{image.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
