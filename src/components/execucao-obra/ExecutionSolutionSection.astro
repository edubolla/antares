---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionImages, executionMessages, executionSteps } from "../../data/execucaoObra";
---

<section id="processo" class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
      <SectionHeader
        eyebrow="Execução Antares"
        title="Como a Antares conduz a execução da sua obra."
        description="Da análise do projeto ao acabamento, a obra é organizada em etapas claras, com planejamento, acompanhamento técnico e comunicação durante o processo."
        tone="dark"
      />
      <CtaLink
        label="Enviar meu projeto"
        message={executionMessages.projectAnalysis}
        variant="light"
      />
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {executionSteps.map((step, index) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-white text-sm font-semibold text-antares-navy">
            {String(index + 1).padStart(2, "0")}
          </span>
          <h3 class="mt-5 text-lg font-semibold tracking-[-0.03em] text-white sm:text-xl">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-white/70">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processStructure}
          alt="Estrutura inicial de obra residencial"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Preparação e estrutura inicial
        </figcaption>
      </figure>

      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processMasonry}
          alt="Alvenaria residencial em execução"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Alvenaria em andamento
        </figcaption>
      </figure>

      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processInterior}
          alt="Interior residencial em etapa de obra"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Execução interna acompanhada
        </figcaption>
      </figure>
    </div>
  </div>
</section>
