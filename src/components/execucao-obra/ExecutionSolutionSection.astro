---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionImages, executionMessages } from "../../data/execucaoObra";

const pillars = [
  {
    title: "Planejamento",
    description: "A obra começa com análise do projeto, escopo e decisões técnicas relevantes.",
  },
  {
    title: "Gestão",
    description: "As etapas são organizadas para reduzir improviso, retrabalho e decisões no escuro.",
  },
  {
    title: "Acompanhamento",
    description: "A execução é acompanhada com comunicação clara sobre avanço e próximos passos.",
  },
];
---

<section class="section-padding bg-antares-navy text-white">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
      <SectionHeader
        eyebrow="Execução Antares"
        title="Execução residencial com planejamento, gestão e acompanhamento técnico."
        description="A Antares organiza as etapas da obra, acompanha a execução e mantém uma comunicação clara para que o projeto avance com previsibilidade."
        tone="dark"
      />
      <CtaLink
        label="Falar com a Antares"
        message={executionMessages.default}
        variant="light"
      />
    </div>

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      {pillars.map((item) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6">
          <p class="text-lg font-semibold text-white">{item.title}</p>
          <p class="mt-3 leading-7 text-white/70">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processFoundation}
          alt="Fundação residencial em etapa inicial de execução"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Fundação e preparação da obra
        </figcaption>
      </figure>

      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processMasonry}
          alt="Alvenaria residencial em execução"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Alvenaria em andamento
        </figcaption>
      </figure>

      <figure class="rounded-[2rem] bg-white/5 p-3">
        <img
          src={executionImages.processInterior}
          alt="Interior residencial em etapa de obra"
          class="h-72 w-full rounded-[1.5rem] object-cover lg:h-96"
          loading="lazy"
        />
        <figcaption class="px-2 pb-1 pt-4 text-sm font-medium text-white/70">
          Execução interna acompanhada
        </figcaption>
      </figure>
    </div>
  </div>
</section>
