---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionImages, executionMessages, executionSteps } from "../../data/execucaoObra";
---

<section id="processo" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1fr] lg:items-end">
      <SectionHeader
        eyebrow="Processo"
        title="Como conduzimos a execução da sua obra."
        description="Analisamos o projeto, planejamos a execução, organizamos as etapas da construção e acompanhamos a evolução da obra com transparência."
      />
      <div class="flex lg:justify-end">
        <CtaLink
          label="Enviar meu projeto"
          message={executionMessages.projectAnalysis}
        />
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {executionSteps.map((step, index) => (
        <div class="premium-card p-5 sm:p-6">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-antares-navy text-sm font-semibold text-white">
            {String(index + 1).padStart(2, "0")}
          </span>
          <h3 class="mt-5 text-lg font-semibold tracking-[-0.03em] text-antares-navy sm:text-xl">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-antares-muted">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      <figure>
        <img
          src={executionImages.processStructure}
          alt="Estrutura inicial de obra residencial"
          class="h-72 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
          loading="lazy"
        />
      </figure>
      <figure>
        <img
          src={executionImages.processMasonry}
          alt="Alvenaria residencial sendo executada"
          class="h-72 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
          loading="lazy"
        />
        <figcaption class="mt-3 text-sm font-medium text-antares-muted">Alvenaria em andamento</figcaption>
      </figure>
      <figure>
        <img
          src={executionImages.processInterior}
          alt="Interior residencial em etapa de obra"
          class="h-72 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
          loading="lazy"
        />
        <figcaption class="mt-3 text-sm font-medium text-antares-muted">Execução interna acompanhada</figcaption>
      </figure>
    </div>
  </div>
</section>
