---
import CtaLink from "../CtaLink.astro";
import { executionImages, executionMessages } from "../../data/execucaoObra";
---

<section class="relative overflow-hidden bg-antares-soft">
  <div class="container-page grid min-h-[calc(100vh-5rem)] items-center gap-12 py-16 lg:grid-cols-[0.95fr_1.05fr] lg:py-24">
    <div class="relative z-10">
      <p class="eyebrow mb-5">Execução de obra residencial</p>
      <h1 class="max-w-4xl text-5xl font-semibold tracking-[-0.06em] text-antares-navy sm:text-6xl lg:text-7xl">
        Já tem o projeto da sua casa? Nós executamos com controle técnico.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-antares-muted sm:text-xl">
        A Antares conduz a execução da sua obra residencial com planejamento, transparência e acompanhamento profissional em cada etapa.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <CtaLink label="Enviar projeto para análise" message={executionMessages.projectAnalysis} />
        <a href="#processo" class="inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-antares-navy transition hover:text-antares-blue">
          Ver como executamos
        </a>
      </div>
      <div class="mt-10 grid max-w-xl gap-3 text-sm text-antares-muted sm:grid-cols-3">
        <div class="rounded-2xl bg-white p-4 shadow-sm">
          <strong class="block text-antares-navy">Projeto existente</strong>
          Recebemos para análise
        </div>
        <div class="rounded-2xl bg-white p-4 shadow-sm">
          <strong class="block text-antares-navy">Escopo avaliado</strong>
          Padrão, prazo e custo
        </div>
        <div class="rounded-2xl bg-white p-4 shadow-sm">
          <strong class="block text-antares-navy">Execução técnica</strong>
          Obra acompanhada
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-8 top-12 h-40 w-40 rounded-full bg-antares-blue/10 blur-3xl"></div>
      <img
        src={executionImages.hero}
        alt="Casa moderna finalizada com alto padrão de execução"
        class="relative aspect-[4/5] w-full rounded-[2rem] object-cover shadow-premium lg:aspect-[5/6]"
        loading="eager"
      />
      <div class="absolute bottom-5 left-5 right-5 rounded-3xl bg-white/90 p-5 shadow-premium backdrop-blur">
        <p class="text-sm font-semibold text-antares-navy">Obra entregue exige execução bem conduzida</p>
        <p class="mt-1 text-sm text-antares-muted">Planejamento, controle técnico e comunicação durante as etapas da construção.</p>
      </div>
    </div>
  </div>
</section>
