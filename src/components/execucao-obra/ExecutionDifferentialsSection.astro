---
import CtaLink from "../CtaLink.astro";
import SectionHeader from "../SectionHeader.astro";
import { executionDifferentials, executionImages, executionMessages } from "../../data/execucaoObra";
---

<section class="section-padding bg-white">
  <div class="container-page grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <SectionHeader
        eyebrow="Diferenciais técnicos"
        title="O que traz segurança durante a construção."
        description="Acompanhamento profissional, cronograma, comunicação constante, atenção aos detalhes e respeito ao projeto arquitetônico."
      />
      <div class="mt-8 grid gap-4">
        {executionDifferentials.map((item) => (
          <article class="rounded-3xl border border-antares-line bg-white p-6 transition hover:-translate-y-1 hover:shadow-premium">
            <h3 class="text-xl font-semibold tracking-[-0.03em] text-antares-navy">{item.title}</h3>
            <p class="mt-3 leading-7 text-antares-muted">{item.description}</p>
          </article>
        ))}
      </div>
      <CtaLink
        label="Quero uma execução segura"
        message={executionMessages.default}
        class="mt-8"
      />
    </div>

    <div class="relative grid gap-4">
      <img
        src={executionImages.differentialDetail}
        alt="Escada e ambiente interno com acabamento técnico finalizado"
        class="aspect-[4/5] w-full rounded-[2rem] object-cover shadow-premium"
        loading="lazy"
      />
      <div class="grid gap-4 sm:grid-cols-2">
        <img
          src={executionImages.differentialKitchen}
          alt="Cozinha finalizada com ilha e marcenaria"
          class="h-56 w-full rounded-[2rem] object-cover shadow-premium"
          loading="lazy"
        />
        <img
          src={executionImages.differentialFinish}
          alt="Detalhe interno finalizado com revestimento e marcenaria"
          class="h-56 w-full rounded-[2rem] object-cover shadow-premium"
          loading="lazy"
        />
      </div>
      <div class="rounded-[2rem] bg-antares-navy p-6 text-white lg:absolute lg:bottom-6 lg:left-6 lg:right-6">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/60">Controle de execução</p>
        <p class="mt-3 text-xl font-semibold tracking-[-0.03em]">
          Detalhes bem resolvidos dependem de acompanhamento técnico durante a obra, não apenas no acabamento.
        </p>
      </div>
    </div>
  </div>
</section>
