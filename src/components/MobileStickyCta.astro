---
import CtaLink from "./CtaLink.astro";

interface Props {
  label: string;
  message?: string;
  href?: string;
}

const { label, message, href } = Astro.props;
---

<div class="fixed inset-x-0 bottom-0 z-50 border-t border-antares-line bg-white/95 p-3 shadow-premium backdrop-blur md:hidden">
  {
    href ? (
      <a
        href={href}
        class="inline-flex w-full items-center justify-center rounded-full bg-antares-blue px-6 py-3 text-sm font-semibold text-white transition hover:bg-antares-navy"
      >
        {label}
      </a>
    ) : (
      <CtaLink label={label} message={message} class="w-full" />
    )
  }
</div>
<div class="h-20 md:hidden" aria-hidden="true"></div>
