---
import { visualDifferentials } from "../../data/execucaoObraB";
---

<section class="section-padding bg-white">
  <div class="container-page">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow mb-4">Diferenciais</p>
      <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">
        Menos improviso. Mais controle.
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {visualDifferentials.map((item) => (
        <div class="rounded-[2rem] border border-antares-line bg-antares-soft p-7">
          <p class="text-2xl font-semibold tracking-[-0.04em] text-antares-navy">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>
