---
import { visualProcess } from "../../data/execucaoObraB";
---

<section id="processo" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow mb-4">Processo</p>
      <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">
        Do projeto à obra.
      </h2>
      <p class="mt-5 text-antares-muted">Um processo técnico. Pouco improviso.</p>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {visualProcess.map((step, index) => (
        <figure class="group relative overflow-hidden rounded-[2.5rem] bg-antares-navy">
          <img
            src={step.image}
            alt={step.alt}
            class="h-[500px] w-full object-cover opacity-90 transition duration-700 group-hover:scale-[1.04]"
            loading="lazy"
          />
          <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-antares-navy to-transparent p-7">
            <span class="text-sm font-semibold text-white/55">{String(index + 1).padStart(2, "0")}</span>
            <p class="mt-2 text-4xl font-semibold tracking-[-0.06em] text-white">{step.title}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
