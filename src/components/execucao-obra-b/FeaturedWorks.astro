---
import { featuredWorks } from "../../data/execucaoObraB";
---

<section id="obras" class="section-padding bg-white">
  <div class="container-page">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow mb-4">Obras em destaque</p>
      <h2 class="text-4xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-6xl">
        Execução que aparece no resultado.
      </h2>
      <p class="mt-5 text-antares-muted">Fachadas, interiores e acabamentos reais da Antares.</p>
    </div>

    <div class="grid gap-4 lg:grid-cols-[1.15fr_0.85fr]">
      <figure class="group relative overflow-hidden rounded-[2.5rem] bg-antares-navy">
        <img
          src={featuredWorks[0].src}
          alt={featuredWorks[0].alt}
          class="h-[620px] w-full object-cover transition duration-700 group-hover:scale-[1.03]"
          loading="lazy"
        />
        <figcaption class="absolute bottom-5 left-5 rounded-full bg-white/90 px-5 py-2 text-sm font-semibold text-antares-navy backdrop-blur">
          {featuredWorks[0].label}
        </figcaption>
      </figure>

      <div class="grid gap-4">
        {featuredWorks.slice(1).map((work) => (
          <figure class="group relative overflow-hidden rounded-[2.5rem] bg-antares-navy">
            <img
              src={work.src}
              alt={work.alt}
              class="h-[302px] w-full object-cover transition duration-700 group-hover:scale-[1.03]"
              loading="lazy"
            />
            <figcaption class="absolute bottom-5 left-5 rounded-full bg-white/90 px-5 py-2 text-sm font-semibold text-antares-navy backdrop-blur">
              {work.label}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </div>
</section>
