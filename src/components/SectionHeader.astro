---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  align?: "left" | "center";
  tone?: "light" | "dark";
}

const { eyebrow, title, description, align = "left", tone = "light" } = Astro.props;
const alignment = align === "center" ? "mx-auto text-center" : "";
const titleColor = tone === "dark" ? "text-white" : "text-antares-navy";
const descriptionColor = tone === "dark" ? "text-white/70" : "text-antares-muted";
---

<div class={`max-w-3xl ${alignment}`}>
  {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
  <h2 class={`text-3xl font-semibold tracking-[-0.04em] sm:text-4xl lg:text-5xl ${titleColor}`}>
    {title}
  </h2>
  <p class={`mt-5 text-base leading-8 sm:text-lg ${descriptionColor}`}>
    {description}
  </p>
</div>
