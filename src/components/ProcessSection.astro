---
import CtaLink from "./CtaLink.astro";
import SectionHeader from "./SectionHeader.astro";
import { images, processSteps } from "../data/landing";
---

<section id="como-funciona" class="section-padding bg-antares-soft">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-end">
      <SectionHeader
        eyebrow="Como funciona"
        title="Você entende cada etapa antes da obra começar."
        description="A construção fica menos assustadora quando você sabe o que vem primeiro, quem resolve cada etapa e quais decisões precisam ser tomadas antes da obra."
      />
      <div class="flex lg:justify-end">
        <CtaLink
          label="Quero entender as etapas"
          message="Olá, quero entender as etapas para construir minha casa, desde o projeto até a execução."
        />
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {processSteps.map((step, index) => (
        <div class="premium-card p-5 sm:p-6">
          <span class="flex h-10 w-10 items-center justify-center rounded-full bg-antares-navy text-sm font-semibold text-white">
            {String(index + 1).padStart(2, "0")}
          </span>
          <h3 class="mt-5 text-lg font-semibold tracking-[-0.03em] text-antares-navy sm:text-xl">{step.title}</h3>
          <p class="mt-3 text-sm leading-6 text-antares-muted">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 grid gap-4 lg:grid-cols-3">
      <img
        src={images.process}
        alt="Projeto residencial em etapa de planejamento"
        class="h-80 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
        loading="lazy"
      />
      <div class="hidden md:block">
        <img
          src={images.processFoundation}
          alt="Fundação residencial em execução"
          class="h-80 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
          loading="lazy"
        />
      </div>
      <div class="hidden md:block">
        <img
          src={images.processInterior}
          alt="Interior residencial em etapa de obra"
          class="h-80 w-full rounded-[2rem] object-cover shadow-premium lg:h-[420px]"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
