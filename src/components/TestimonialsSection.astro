---
import CtaLink from "./CtaLink.astro";
import SectionHeader from "./SectionHeader.astro";
import { images, testimonials } from "../data/landing";
---

<section id="depoimentos" class="section-padding bg-white">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2.5rem] bg-antares-navy px-5 py-16 text-white shadow-premium sm:px-8 lg:px-10 lg:py-20">
      <img
        src={images.testimonial}
        alt="Casa entregue usada como prova social"
        class="absolute inset-0 h-full w-full object-cover opacity-20 mix-blend-luminosity"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-br from-antares-navy via-antares-navy/95 to-antares-blue/85"></div>

      <div class="relative z-10">
        <SectionHeader
          eyebrow="Depoimentos"
          title="Clientes reais reforçam o que mais importa: confiança para construir."
          description="Os relatos destacam atendimento, solução de problemas, cumprimento do projeto, prazo e cuidado com as necessidades da família."
          tone="dark"
          align="center"
        />

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {testimonials.map((testimonial) => (
            <blockquote class="rounded-[2rem] border border-white/15 bg-white/10 p-6 backdrop-blur">
              <p class="text-base leading-7 text-white/90">"{testimonial.quote}"</p>
              <footer class="mt-6 font-semibold text-white">{testimonial.name}</footer>
            </blockquote>
          ))}
        </div>

        <div class="mt-10 text-center">
          <CtaLink
            label="Quero conversar com a equipe"
            message="Olá, vi os depoimentos e gostaria de conversar com a equipe Antares sobre minha construção."
            variant="light"
            class="mt-2"
          />
        </div>
      </div>
    </div>
  </div>
</section>
