---
import CtaLink from "./CtaLink.astro";
import SectionHeader from "./SectionHeader.astro";
import { images, testimonials } from "../data/landing";
---

<section id="depoimentos" class="section-padding bg-white">
  <div class="container-page">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <SectionHeader
          eyebrow="Depoimentos"
          title="Clientes reais reforçam o que mais importa: confiança para construir."
          description="Os relatos destacam atendimento, solução de problemas, cumprimento do projeto, prazo e cuidado com as necessidades da família."
        />
        <img
          src={images.testimonial}
          alt="Casa entregue usada como prova social"
          class="mt-8 aspect-[4/3] w-full rounded-[2rem] object-cover shadow-premium"
          loading="lazy"
        />
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {testimonials.map((testimonial) => (
          <blockquote class="rounded-[2rem] border border-antares-line bg-antares-soft p-6">
            <p class="text-base leading-7 text-antares-ink sm:text-lg sm:leading-8">"{testimonial.quote}"</p>
            <footer class="mt-5 font-semibold text-antares-navy">{testimonial.name}</footer>
          </blockquote>
        ))}
        <div class="sm:col-span-2">
          <CtaLink
            label="Quero conversar com a equipe"
            message="Olá, vi os depoimentos e gostaria de conversar com a equipe Antares sobre minha construção."
            class="mt-2"
          />
        </div>
      </div>
    </div>
  </div>
</section>
