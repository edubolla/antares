---
import CtaLink from "./CtaLink.astro";
import SectionHeader from "./SectionHeader.astro";
import { images } from "../data/landing";

const pillars = [
  {
    title: "Projeto",
    description: "A planta nasce conectada ao terreno, à rotina da família e à viabilidade da obra.",
  },
  {
    title: "Documentação",
    description: "As aprovações e pontos técnicos entram no processo antes de virarem atraso.",
  },
  {
    title: "Construção",
    description: "A execução segue o que foi planejado, com acompanhamento profissional.",
  },
];
---

<section class="section-padding bg-antares-navy text-white">
  <div class="container-page grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
    <div class="overflow-hidden rounded-[2rem] bg-white/5 p-3">
      <img
        src={images.solution}
        alt="Projeto residencial usado no planejamento de construção"
        class="aspect-[4/5] w-full rounded-[1.5rem] object-cover"
        loading="lazy"
      />
    </div>

    <div>
      <SectionHeader
        eyebrow="Solução integrada"
        title="Um único parceiro para planejar, aprovar e construir sua casa."
        description="Em vez de coordenar arquiteto, engenheiro, documentação e obra separadamente, você tem uma equipe conduzindo o processo completo com método e acompanhamento."
        tone="dark"
      />
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {pillars.map((item) => (
          <div class="rounded-3xl border border-white/10 bg-white/5 p-5">
            <p class="font-semibold text-white">{item.title}</p>
            <p class="mt-2 text-sm leading-6 text-white/70">{item.description}</p>
          </div>
        ))}
      </div>
      <CtaLink
        label="Falar sobre meu terreno"
        message="Olá, tenho um terreno e quero falar com a Antares sobre projeto, documentação e construção."
        variant="light"
        class="mt-8"
      />
    </div>
  </div>
</section>
