---
import BaseLayout from "../layouts/BaseLayout.astro";
import ConstrutoraBenefits from "../components/construtora/ConstrutoraBenefits.astro";
import ConstrutoraFaq from "../components/construtora/ConstrutoraFaq.astro";
import ConstrutoraFinalCta from "../components/construtora/ConstrutoraFinalCta.astro";
import ConstrutoraHero from "../components/construtora/ConstrutoraHero.astro";
import ConstrutoraMoment from "../components/construtora/ConstrutoraMoment.astro";
import ConstrutoraPortfolio from "../components/construtora/ConstrutoraPortfolio.astro";
import ConstrutoraProblemSolution from "../components/construtora/ConstrutoraProblemSolution.astro";
import ConstrutoraProofBar from "../components/construtora/ConstrutoraProofBar.astro";
import ConstrutoraTestimonials from "../components/construtora/ConstrutoraTestimonials.astro";
import FloatingWhatsApp from "../components/FloatingWhatsApp.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import MobileStickyCta from "../components/MobileStickyCta.astro";
import { construtoraMessages } from "../data/construtora";
---

<BaseLayout
  title="Antares Construtora | Empresa para Construir Casa em Canoas e Região"
  description="A empresa certa para construir sua casa do zero em Canoas e região. Projeto, documentação e execução com uma única equipe, do desenho à entrega da chave."
>
  <Header navItems={[]} ctaLabel="Falar com a Antares" ctaMessage={construtoraMessages.default} />
  <main>
    <ConstrutoraHero />
    <ConstrutoraProofBar />
    <ConstrutoraMoment />
    <ConstrutoraProblemSolution />
    <ConstrutoraBenefits />
    <ConstrutoraPortfolio />
    <ConstrutoraTestimonials />
    <ConstrutoraFaq />
    <ConstrutoraFinalCta />
  </main>
  <Footer
    description="Construção residencial do zero em Canoas e região: projeto, documentação e execução completa."
    ctaLabel="Falar com a Antares"
    ctaMessage={construtoraMessages.default}
  />
  <FloatingWhatsApp message={construtoraMessages.default} showLabel />
  <MobileStickyCta label="Falar com a Antares" message={construtoraMessages.default} />
</BaseLayout>
