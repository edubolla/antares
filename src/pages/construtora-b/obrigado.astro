---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { construtoraBCopy, construtoraBPaths, construtoraBWhatsAppUrl } from "../../data/construtora-b";
import { contact, images } from "../../data/landing";
---

<BaseLayout
  title="Obrigado | Antares Construtora"
  description="Recebemos seus dados. Em breve a equipe Antares entrará em contato com você."
  trackScroll={false}
  trackClicks={false}
>
  <main class="min-h-screen bg-antares-soft">
    <div class="container-page flex min-h-screen flex-col items-center justify-center py-16 text-center">
      <div class="inline-flex rounded-2xl bg-white px-4 py-3 shadow-premium">
        <img src={images.logoBlue} alt="Antares Construtora" class="h-12 w-auto" />
      </div>

      <div class="premium-card mt-10 max-w-xl p-8 sm:p-10">
        <p class="eyebrow mb-4">Solicitação enviada</p>
        <h1 class="text-3xl font-semibold tracking-[-0.05em] text-antares-navy sm:text-4xl">
          {construtoraBCopy.obrigado.title}
        </h1>
        <p class="mt-4 text-lg font-medium text-antares-navy">{construtoraBCopy.obrigado.subtitle}</p>
        <p class="mt-4 leading-7 text-antares-muted">{construtoraBCopy.obrigado.body}</p>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          <a
            href={construtoraBWhatsAppUrl()}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#1FBD5A]"
          >
            <svg viewBox="0 0 32 32" aria-hidden="true" class="h-5 w-5 fill-current">
              <path d="M16.04 3.2A12.74 12.74 0 0 0 5.06 22.4L3.2 29l6.76-1.78A12.73 12.73 0 1 0 16.04 3.2Zm0 23.28a10.6 10.6 0 0 1-5.4-1.48l-.38-.23-4.02 1.06 1.07-3.92-.25-.4a10.55 10.55 0 1 1 8.98 4.97Zm5.8-7.91c-.32-.16-1.88-.93-2.17-1.03-.29-.11-.5-.16-.71.16-.21.32-.82 1.03-1.01 1.24-.18.21-.37.24-.69.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.88-1.76-2.2-.18-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.18.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.71-1.7-.98-2.33-.26-.62-.52-.53-.71-.54h-.61c-.21 0-.56.08-.85.4-.29.32-1.11 1.08-1.11 2.64 0 1.56 1.14 3.07 1.3 3.28.16.21 2.25 3.43 5.44 4.81.76.33 1.35.52 1.81.67.76.24 1.46.21 2.01.13.61-.09 1.88-.77 2.15-1.51.26-.74.26-1.38.18-1.51-.08-.13-.29-.21-.61-.37Z" />
            </svg>
            {construtoraBCopy.obrigado.whatsappCta}
          </a>

          <a
            href={construtoraBPaths.lp}
            class="inline-flex items-center justify-center rounded-full border border-antares-line bg-white px-6 py-3 text-sm font-semibold text-antares-navy transition hover:border-antares-blue hover:text-antares-blue"
          >
            {construtoraBCopy.obrigado.backCta}
          </a>
        </div>

        <p class="mt-4 text-sm text-antares-muted">{construtoraBCopy.obrigado.whatsappHint}</p>
      </div>

      <p class="mt-10 max-w-md text-sm text-antares-muted">{contact.address}</p>
    </div>
  </main>
</BaseLayout>
